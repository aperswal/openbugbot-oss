FROM --platform=linux/amd64 golang:1.26-bookworm AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY cmd/reviewer ./cmd/reviewer
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -trimpath -ldflags='-s -w' -o /openbugbot-reviewer ./cmd/reviewer

FROM --platform=linux/amd64 debian:bookworm-slim
RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates curl git \
  && rm -rf /var/lib/apt/lists/*
RUN curl -fsSL https://chatgpt.com/codex/install.sh | CODEX_NON_INTERACTIVE=1 sh
COPY --from=build /openbugbot-reviewer /usr/local/bin/openbugbot-reviewer
ENV PORT=8080
ENV PATH="/root/.local/bin:${PATH}"
EXPOSE 8080
ENTRYPOINT ["openbugbot-reviewer"]
