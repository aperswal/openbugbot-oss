# Copy this file to .env. It is shell-compatible: deployment scripts load it
# automatically, and Terraform can use it with `set -a; . ./.env; set +a`.
# Do not commit .env or the files in ./secrets.

# Cloudflare account credentials. Create a scoped API token as described in the
# README; do not use a Global API key.
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ACCOUNT_ID=""
TF_VAR_cloudflare_account_id=""

# Optional custom domain for the reviewer Worker. Leave it empty
# to use the workers.dev URLs printed by Wrangler.
REVIEWER_WORKER_ROUTE=""

# GitHub App configuration for the reviewer Worker.
GITHUB_APP_ID=""
GITHUB_WEBHOOK_SECRET=""
GITHUB_APP_PRIVATE_KEY_FILE="./secrets/github-app-private-key.pem"

# Generate this separate RSA key pair for OpenBugbot. The private key stays on
# the reviewer Worker; the public key is used by each CLI client to encrypt its
# Codex auth before enrollment.
AUTH_ENCRYPTION_PRIVATE_KEY_FILE="./secrets/auth-encryption-private-key.pem"
AUTH_ENCRYPTION_PUBLIC_KEY_FILE="./secrets/auth-encryption-public-key.pem"

# CLI client configuration. Use your reviewer Worker URL, for example:
# https://openbugbot-reviewer.<your-workers-subdomain>.workers.dev/enroll
OPENBUGBOT_ENROLL_URL=""
OPENBUGBOT_AUTH_PUBLIC_KEY_FILE="./secrets/auth-encryption-public-key.pem"
